# Cloudflared tunnel config template — operator copies to config.yml
# (NOT committed; .gitignore'd) and customizes per-environment.
#
# v1 (THIS COMMIT): tunnel is OPTIONAL. The worker posts outbound to
# api.levelog.com which doesn't require any tunnel routing. Cloudflared's
# value in v1 is stable residential-IP egress IF the operator's ISP
# starts rotating IPs in ways Akamai disliked.
#
# v2: ingress rule added so the cloud can ping the worker for
# interactive prompts (CAPTCHA / 2FA). Until then, leave ingress empty
# (or commented out — cloudflared will refuse to start with an empty
# ingress array).
#
# Operator pre-deploy:
#   1. cloudflared login   (browser flow, authorizes against the
#                           LeveLog Cloudflare company account)
#   2. cloudflared tunnel create agent-tunnel-1
#      → produces credentials.json with a UUID and account ID
#   3. Copy the credentials JSON to ./cloudflared/credentials.json
#   4. Replace <TUNNEL_UUID> below with the UUID from step 2
#   5. Uncomment the cloudflared service in docker-compose.yml
#   6. docker compose up -d cloudflared

tunnel: <TUNNEL_UUID>
credentials-file: /etc/cloudflared/credentials.json

# v1: ingress is empty — no inbound routes. Cloudflared still
# provides stable egress through the LeveLog account's IP pool.
# Uncomment v2's ingress block when adding the inbound webhook channel.
# ingress:
#   - hostname: agent.levelog.com
#     service: http://dob_worker:8002
#   - service: http_status:404
