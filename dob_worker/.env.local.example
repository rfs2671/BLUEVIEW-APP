# dob_worker — environment template.
# Copy to ./dob_worker/.env.local (NOT committed — .gitignore'd)
# and fill in real values. Operator-only file.

# ── Core integration ──────────────────────────────────────────────

# Railway Redis add-on connection string. From Railway dashboard
# after adding the Redis plugin to the project.
REDIS_URL=redis://default:<password>@<host>:<port>

# Cloud backend URL. Production: https://api.levelog.com
# Local dev: http://host.docker.internal:8001 (Docker Desktop magic
# DNS to reach a uvicorn running on the host).
BACKEND_URL=https://api.levelog.com

# Shared secret for /api/internal/* auth. Set the SAME value on
# Railway's backend service env as WORKER_SECRET. The worker sends
# X-Worker-Secret on every internal POST.
WORKER_SECRET=<generate-with-openssl-rand-hex-32>

# Cloudflare Access JWT (optional in v1; required in v2). If the
# Access policy is enabled on /api/internal/*, the worker passes
# this in cf-access-jwt header.
CF_ACCESS_JWT_OPTIONAL=

# Stable identifier for THIS worker instance — used as the upsert
# key on agent_heartbeats. Pick something memorable per host:
WORKER_ID=dob-worker-roey-laptop-1

# ── Crypto ────────────────────────────────────────────────────────

# Bind-mount target inside the container. The host path is set
# separately as LEVELOG_AGENT_KEYS_DIR for docker-compose to mount.
PRIVATE_KEY_PATH=/keys/agent.key

# ── Storage state (re-engaged in MR.13) ──────────────────────────
# Per-GC storage_state path inside the worker container. Bind-mounted
# from ${LEVELOG_AGENT_STORAGE_DIR} on the host. The dob_now_filing
# handler loads <license>/current.json on context create and saves
# it back on success (MR.11.3 preserve-on-failure semantics — failed
# runs don't overwrite the seeded session).

STORAGE_STATE_DIR=/storage

# ── Mode gate ─────────────────────────────────────────────────────

# Worker refuses dob_now_filing jobs if not 'live'. Defends against
# shadow-mode test enqueues hitting the live filing path.
ELIGIBILITY_REWRITE_MODE=live

# ── Existing bis_scrape passthrough ───────────────────────────────
# These were on the original bis_scraper Railway service; preserved
# here so the rename doesn't break the BIS scraping behavior.

MONGO_URL=mongodb+srv://...
DB_NAME=blueview
RESEND_API_KEY=
# WEBSHARE_PROXY_URL is read by:
#   1. handlers/bis_scrape.py (legacy BIS, no Akamai).
#   2. handlers/dob_now_filing.py via lib.browser_launch.get_proxy_args
#      (MR.13 — optional fallback). When set, the dob_now_filing
#      handler routes Chrome's egress through this residential
#      proxy instead of operator's home ISP. Default v1 path is
#      direct (unset). Layer Webshare back in if Akamai starts
#      flagging operator's IP.
WEBSHARE_PROXY_URL=
BIS_SCAN_INTERVAL_MIN=60
BIS_SCAN_CONCURRENCY=2
BIS_DEBUG_HTML=0

# ── Host-side bind-mount paths (READ by docker-compose, NOT by
# the worker process). Cross-platform:
#   Windows:    C:\Users\<u>\.levelog\agent-keys
#   Linux/Mac:  /home/<u>/.levelog/agent-keys
# Set these in your SHELL environment (not this .env.local file —
# Compose only reads .env from the project root for variable
# substitution; we keep them here as documentation):
#
# LEVELOG_AGENT_KEYS_DIR=...
# LEVELOG_AGENT_STORAGE_DIR=...
