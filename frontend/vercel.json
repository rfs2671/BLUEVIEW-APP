{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/checkin/:path*",
      "destination": "https://blueview2-production.up.railway.app/checkin/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://blueview2-production.up.railway.app/api/:path*"
    },
    {
      "source": "/a/:annotation_id",
      "destination": "https://blueview2-production.up.railway.app/a/:annotation_id"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
