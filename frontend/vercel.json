{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "blue-view.app" }],
      "destination": "https://levelog.com/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.blue-view.app" }],
      "destination": "https://levelog.com/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/checkin/:path*",
      "destination": "https://api.levelog.com/checkin/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://api.levelog.com/api/:path*"
    },
    {
      "source": "/a/:annotation_id",
      "destination": "https://api.levelog.com/a/:annotation_id"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
